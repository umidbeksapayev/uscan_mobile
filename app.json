{
  "expo": {
    "name": "uscan",
    "slug": "uscan",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "uscan",
    "userInterfaceStyle": "light",
    "ios": {
      "bundleIdentifier": "uz.uscan.app",
      "supportsTablet": false,
      "infoPlist": {
        "NSCameraUsageDescription": "Mahsulot shtrix-kodini skanerlash uchun kamera kerak."
      }
    },
    "android": {
      "package": "uz.uscan.app",
      "adaptiveIcon": {
        "backgroundColor": "#0F3D6E",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0F3D6E",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "Mahsulot shtrix-kodini skanerlash uchun kamera kerak.",
          "enableCodeScanner": true
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Mahsulot rasmini galereyadan tanlash uchun ruxsat kerak.",
          "cameraPermission": "Mahsulot rasmini kamerada olish uchun ruxsat kerak."
        }
      ],
      "expo-sqlite"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "webUrl": "",
      "eas": {
        "projectId": "554a4a4a-43a6-4972-9a4f-2f76a0d7970a"
      }
    },
    "owner": "umid_0571"
  }
}
